<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TheTagHag</RootNamespace>
    <AssemblyName>TheTagHag</AssemblyName>
    <Version>2.4.0</Version>
    <Authors>Angry Munky</Authors>
    <Company>Angry Munky</Company>
    <Product>The Tag Hag</Product>
    <Description>Portable Windows app to scan, search, and sift a large local library of AI-generated images by their prompt metadata.</Description>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <!-- Hag-tag app icon (generated by IconMaker, see the makeicon CLI flag); baked into the exe. -->
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>

    <!-- Single-file self-contained publish (T1 proves SQLite/FTS5 survives this model):
         dotnet publish -c Release -o publish -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <DebugType>embedded</DebugType>
    <PublishReferencesDocumentationFiles>false</PublishReferencesDocumentationFiles>
    <PublishDocumentationFile>false</PublishDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Live local store. Pulls SQLitePCLRaw.bundle_e_sqlite3 (includes FTS5, ships the
         native lib). Self-extracts under the single-file flags above — no extra config. -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.*" />
    <!-- EXIF (JPEG/WebP) read + later resize/thumbnail (T14/T15). -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    <!-- Gallery host (T10). -->
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2792.45" />
    <!-- PNG CRC-32 (ISO-HDLC) for re-splicing metadata chunks on downsample (T14). -->
    <PackageReference Include="System.IO.Hashing" Version="8.0.0" />
    <!-- DPAPI encryption for the Civitai API key (T16/T17). -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Dark Magic Pro gallery markup, embedded so the published exe is self-contained. -->
    <EmbeddedResource Include="Resources\taghag.template.html" />
    <EmbeddedResource Include="Resources\browse.template.html" />
    <!-- App icon embedded too, so every window (titlebar/alt-tab) can set it at runtime. -->
    <EmbeddedResource Include="Resources\app.ico" />
    <!-- Brand lockup (hag + TAG HAG) shown in the sidebar; extracted next to the app page at runtime. -->
    <EmbeddedResource Include="Resources\logo-lockup.png" />
  </ItemGroup>

  <!-- NOTE: ProtectedData / TaskScheduler arrive with their tickets (T16/T17). -->

  <!-- The PUBLIC mirror (a separate git repo, AngryMunky/tag-hag) lives nested at tag-hag\ inside
       this project folder after the 2026-06-23 consolidation. It carries its own copy of every
       source file + an obj\ with generated .cs, which the SDK's default **/*.cs / EmbeddedResource
       globs would otherwise compile into THIS app (CS0111 duplicate-definition errors). Exclude the
       entire mirror subtree from this project's default item globs — it is built from its own csproj. -->
  <ItemGroup>
    <Compile Remove="tag-hag\**\*.cs" />
    <EmbeddedResource Remove="tag-hag\**" />
    <None Remove="tag-hag\**" />
    <Content Remove="tag-hag\**" />
  </ItemGroup>

</Project>
